<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ImageView hiển thị bitmap đã vẽ box trực tiếp -->
    <ImageView
        android:id="@+id/camera_image_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        android:background="#000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/recycler_view" />

    <!-- Debug image view -->
    <com.ducnguyen.trafficsign.ui.DebugImageView
        android:id="@+id/debug_image_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="#111111"
        app:layout_constraintTop_toTopOf="@id/camera_image_view"
        app:layout_constraintBottom_toBottomOf="@id/camera_image_view"
        app:layout_constraintStart_toStartOf="@id/camera_image_view"
        app:layout_constraintEnd_toEndOf="@id/camera_image_view" />

    <!-- Danh sách biển - bên phải 30% -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#CC1a1a1a"
        android:padding="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.30"
        app:layout_constraintStart_toEndOf="@id/camera_image_view" />

    <!-- Debug toggle button -->
    <Button
        android:id="@+id/btn_debug"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Debug"
        android:textSize="11sp"
        android:alpha="0.85"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/recycler_view"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="6dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
